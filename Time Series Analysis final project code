    "# competition models: ARIMA + Fourier(K=6) via MLE\n\n# iteration 1: ARIMA(1,0,0) + Fourier(K=6), post-break window (Nov 2019+)\ny_short = y_sub['2019-11-01':]\ndp_short = DeterministicProcess(index=y_short.index, constant=False, period=12, fourier=6, order=0)\nm_short = ARIMA(y_short, order=(1,0,0), exog=dp_short.in_sample()).fit()\nfc_iter1 = m_short.forecast(12, exog=dp_short.out_of_sample(12)).values\n\n# iteration 2: ARIMA(3,0,1) + Fourier(K=6), long window (Jun 2017+)\ny_long = y['2017-06-01':]\ndp_long = DeterministicProcess(index=y_long.index, constant=False, period=12, fourier=6, order=0)\nm_long = ARIMA(y_long, order=(3,0,1), exog=dp_long.in_sample()).fit()\nfc_iter2 = m_long.forecast(12, exog=dp_long.out_of_sample(12)).values\n\n# iteration 3: 50/50 blend\nfc_iter3 = 0.5 * fc_iter1 + 0.5 * fc_iter2\n\n# iteration 4: AIC-guided AR(2) + extended short window\nprint('=== Iteration 4: AIC comparison for short-window model ===')\nprint(f'\\nNov 2019 window (n={len(y_short)}):')\nprint(f'  ARIMA(1,0,0)+F6: AIC = {m_short.aic:.1f}')\n\nm_ar2_nov = ARIMA(y_short, order=(2,0,0), exog=dp_short.in_sample()).fit()\nprint(f'  ARIMA(2,0,0)+F6: AIC = {m_ar2_nov.aic:.1f}  (delta = {m_ar2_nov.aic - m_short.aic:.1f})')\n\ny_short_ext = y['2019-06-01':]\ndp_short_ext = DeterministicProcess(index=y_short_ext.index, constant=False, period=12, fourier=6, order=0)\nm_ar1_jun = ARIMA(y_short_ext, order=(1,0,0), exog=dp_short_ext.in_sample()).fit()\nm_ar2_jun = ARIMA(y_short_ext, order=(2,0,0), exog=dp_short_ext.in_sample()).fit()\n\nprint(f'\\nJun 2019 window (n={len(y_short_ext)}):')\nprint(f'  ARIMA(1,0,0)+F6: AIC = {m_ar1_jun.aic:.1f}')\nprint(f'  ARIMA(2,0,0)+F6: AIC = {m_ar2_jun.aic:.1f}  (delta = {m_ar2_jun.aic - m_ar1_jun.aic:.1f})')\n\nfc_iter4_short = m_ar2_jun.forecast(12, exog=dp_short_ext.out_of_sample(12)).values\nfc_iter4 = 0.5 * fc_iter4_short + 0.5 * fc_iter2\n\n# iteration 5: standardize long window on AR(2)\nprint(f'\\n=== Iteration 5: AIC comparison for long-window model ===')\nprint(f'\\nJun 2017 window (n={len(y_long)}):')\nprint(f'  ARIMA(3,0,1)+F6: AIC = {m_long.aic:.1f}  (4 ARIMA params)')\nm_long_ar2 = ARIMA(y_long, order=(2,0,0), exog=dp_long.in_sample()).fit()\nprint(f'  ARIMA(2,0,0)+F6: AIC = {m_long_ar2.aic:.1f}  (2 ARIMA params)')\n\nfc_iter5_long = m_long_ar2.forecast(12, exog=dp_long.out_of_sample(12)).values\nfc_comp = 0.5 * fc_iter4_short + 0.5 * fc_iter5_long\n\n# forecast comparison across all iterations\nprint(f'\\n=== Forecast values by iteration ===')\nprint(f\"{'Month':<6} {'Iter1':>8} {'Iter2':>8} {'Iter3':>8} {'Iter4':>8} {'Iter5':>8}\")\nprint('-' * 48)\nmonths = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\nfor i, m in enumerate(months):\n    print(f'{m:<6} {fc_iter1[i]:>8.0f} {fc_iter2[i]:>8.0f} {fc_iter3[i]:>8.0f} {fc_iter4[i]:>8.0f} {fc_comp[i]:>8.0f}')\n\n# Kaggle-confirmed public RMSE scores:\n# Conservative blend (SARIMA+STL+F4):  173.3\n# Iteration 1 (AR1+F6, Nov 2019):      154.2\n# Iteration 2 (AR3MA1+F6, Jun 2017):   202.7\n# Iteration 3 (50/50 blend):           127.8\n# Iteration 4 (AR2 Jun 2019 + old):    118.0\n# Iteration 5 (AR2 both windows):      109.4\n\nfig, ax = plt.subplots(figsize=(12, 6))\nax.plot(y_sub.index, y_sub, color='grey', label='observed')\nfc_idx = pd.date_range('2025-01-01', periods=12, freq='MS')\nax.plot(fc_idx, fc_iter1, '--', color='steelblue', alpha=0.4, label='iter 1: AR(1)+F6, Nov 2019 (pub 154.2)')\nax.plot(fc_idx, fc_iter2, '--', color='orange', alpha=0.4, label='iter 2: AR(3,1)+F6, Jun 2017 (pub 202.7)')\nax.plot(fc_idx, fc_iter3, '--', color='purple', alpha=0.4, label='iter 3: 50/50 blend (pub 127.8)')\nax.plot(fc_idx, fc_iter4, '--', color='green', alpha=0.5, label='iter 4: AR(2)+F6 short + old long (pub 118.0)')\nax.plot(fc_idx, fc_comp, color='darkred', linewidth=2, label='iter 5: AR(2)+F6 both windows (pub 109.4)')\nax.plot(fc_idx, fc_2025.values, ':', color='grey', alpha=0.5, label='conservative blend (pub 173.3)')\nax.set_title('Competition Refinement: ARIMA + Fourier(K=6) via MLE')\nax.legend(fontsize=8, loc='upper left')\nax.set_ylabel('Job Openings (thousands)')\nplt.tight_layout()\nplt.show()\n\n# FINAL KAGGLE SUBMISSION\nsubmission_comp = pd.DataFrame({'date': range(1, 13), 'jobs': np.round(fc_comp).astype(int)})\nsubmission_comp.to_csv('submission.csv', index=False)\nprint('\\n' + '='*50)\nprint('FINAL KAGGLE SUBMISSION saved to submission.csv')\nprint('='*50)\nprint('Model: 50/50 blend of two ARIMA(2,0,0)+Fourier(K=6) models')\nprint('  Short window: Jun 2019 (67 obs)')\nprint('  Long window:  Jun 2017 (91 obs)')\nprint(f'Public RMSE: 109.4')"
