    "# formal structural break tests\n",
    "from statsmodels.tsa.stattools import zivot_andrews\n",
    "\n",
    "# rolling Chow test on the full series\n",
    "t_arr = np.arange(len(y))\n",
    "X_full = sm.add_constant(t_arr)\n",
    "ols_full = sm.OLS(y.values, X_full).fit()\n",
    "rss_full = np.sum(ols_full.resid**2)\n",
    "n, k = len(y), 2\n",
    "\n",
    "chow_dates, chow_f, chow_p = [], [], []\n",
    "for bi in range(15, len(y)-15):\n",
    "    X_pre = sm.add_constant(t_arr[:bi])\n",
    "    rss_pre = np.sum(sm.OLS(y.values[:bi], X_pre).fit().resid**2)\n",
    "    X_post = sm.add_constant(t_arr[bi:])\n",
    "    rss_post = np.sum(sm.OLS(y.values[bi:], X_post).fit().resid**2)\n",
    "    F = ((rss_full - (rss_pre + rss_post)) / k) / ((rss_pre + rss_post) / (n - 2*k))\n",
    "    chow_dates.append(y.index[bi])\n",
    "    chow_f.append(F)\n",
    "    chow_p.append(1 - stats.f.cdf(F, k, n - 2*k))\n",
    "\n",
    "# plot\n",
    "f_crit_05 = stats.f.ppf(0.95, k, n - 2*k)\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.plot(chow_dates, chow_f, color='grey')\n",
    "plt.axhline(y=f_crit_05, color='darkred', linestyle='--', label=f'5% critical value ({f_crit_05:.2f})')\n",
    "plt.fill_between(chow_dates, chow_f, f_crit_05,\n",
    "                 where=[f > f_crit_05 for f in chow_f], alpha=0.3, color='darkred')\n",
    "plt.title('Rolling Chow Test for Structural Break')\n",
    "plt.ylabel('F-statistic')\n",
    "plt.legend()\n",
    "plt.show()\n",
    "\n",
    "# peak\n",
    "peak_idx = np.argmax(chow_f)\n",
    "print(f'Most significant break: {chow_dates[peak_idx].date()}, F = {chow_f[peak_idx]:.2f}, p = {chow_p[peak_idx]:.6f}')\n",
    "\n",
    "# key dates\n",
    "for label, dt in [('Jan 2019', '2019-01-01'), ('Oct 2019', '2019-10-01'),\n",
    "                  ('Jan 2020', '2020-01-01'), ('Mar 2020', '2020-03-01'),\n",
    "                  ('Apr 2020', '2020-04-01'), ('Jun 2020', '2020-06-01')]:\n",
    "    idx = [i for i, d in enumerate(chow_dates) if d == pd.Timestamp(dt)]\n",
    "    if idx:\n",
    "        i = idx[0]\n",
    "        sig = '***' if chow_p[i] < 0.01 else '**' if chow_p[i] < 0.05 else ''\n",
    "        print(f'  {label}: F = {chow_f[i]:.2f}, p = {chow_p[i]:.4f} {sig}')\n",
    "\n",
    "# Zivot-Andrews\n",
    "za_ct = zivot_andrews(y.values, regression='ct')\n",
    "za_break = y.index[za_ct[4]]\n",
    "print(f'\\nZivot-Andrews (ct): break at {za_break.date()}, stat = {za_ct[0]:.4f}, p = {za_ct[1]:.4f}')\n",
    "print(f'  5% critical value: {za_ct[2][\"5%\"]:.3f}')"
   ],
